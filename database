-- VIEWS


-- Low stock
CREATE OR REPLACE VIEW vw_low_stock AS
SELECT
    p.id              AS product_id,
    p.name            AS product_name,
    p.barcode,
    c.name            AS category,
    i.quantity_in_stock,
    i.quantity_reserved,
    i.quantity_available,
    p.min_stock_level,
    p.reorder_level,
    p.expiry_date,
    i.warehouse_location
FROM inventory i
JOIN products p ON p.id = i.product_id
LEFT JOIN categories c ON c.id = p.category_id
WHERE i.quantity_available <= p.reorder_level
  AND p.is_active = TRUE
ORDER BY i.quantity_available ASC;


-- Expiring products (30 days)
CREATE OR REPLACE VIEW vw_expiring_products AS
SELECT
    p.id              AS product_id,
    p.name            AS product_name,
    c.name            AS category,
    p.expiry_date,
    DATEDIFF(p.expiry_date, CURDATE()) AS days_until_expiry,
    i.quantity_in_stock,
    i.warehouse_location
FROM products p
JOIN inventory i ON i.product_id = p.id
LEFT JOIN categories c ON c.id = p.category_id
WHERE p.expiry_date IS NOT NULL
  AND p.expiry_date <= DATE_ADD(CURDATE(), INTERVAL 30 DAY)
  AND p.is_active = TRUE
ORDER BY p.expiry_date ASC;


-- All outstanding debts
CREATE OR REPLACE VIEW vw_outstanding_debts AS
SELECT
    d.id              AS debt_id,
    d.debt_number,
    d.original_amount,
    d.paid_amount,
    d.remaining_amount,
    d.due_date,
    DATEDIFF(CURDATE(), d.due_date) AS days_overdue,
    d.last_payment_date,
    d.status,
    d.notes
FROM debts d
WHERE d.status IN ('active', 'partially_paid', 'overdue')
ORDER BY d.due_date ASC;


-- Rep sales summary
CREATE OR REPLACE VIEW vw_rep_sales_summary AS
SELECT
    e.id              AS representative_id,
    CONCAT(e.first_name, ' ', e.last_name) AS representative_name,
    COUNT(s.id)       AS total_orders,
    SUM(s.total_amount) AS total_sales,
    SUM(s.paid_amount)  AS total_collected,
    SUM(s.due_amount)   AS total_outstanding,
    COUNT(CASE WHEN s.order_status    = 'delivered' THEN 1 END) AS delivered_orders,
    COUNT(CASE WHEN s.order_status    = 'cancelled' THEN 1 END) AS cancelled_orders,
    COUNT(CASE WHEN s.approval_status = 'pending'   THEN 1 END) AS pending_approval,
    COUNT(CASE WHEN s.approval_status = 'rejected'  THEN 1 END) AS rejected_orders
FROM employees e
LEFT JOIN sales s ON s.representative_id = e.id
WHERE e.is_representative = TRUE
GROUP BY e.id, representative_name;


-- Pending rep orders (accountant dashboard)
CREATE OR REPLACE VIEW vw_pending_rep_orders AS
SELECT
    s.id              AS sale_id,
    s.sale_number,
    s.sale_date,
    CONCAT(e.first_name, ' ', e.last_name) AS representative_name,
    CONCAT(c.first_name, ' ', IFNULL(c.last_name, '')) AS customer_name,
    s.total_amount,
    s.order_type,
    s.approval_status,
    s.created_at
FROM sales s
LEFT JOIN employees e ON e.id = s.representative_id
LEFT JOIN customers c ON c.id = s.customer_id
WHERE s.order_type = 'representative'
  AND s.approval_status = 'pending'
ORDER BY s.created_at ASC;


-- Monthly financials
CREATE OR REPLACE VIEW vw_monthly_financials AS
SELECT
    yr, mn,
    IFNULL(total_revenue, 0)  AS total_revenue,
    IFNULL(total_expenses, 0) AS total_expenses,
    IFNULL(total_revenue, 0) - IFNULL(total_expenses, 0) AS net_profit
FROM (
    SELECT YEAR(sale_date) AS yr, MONTH(sale_date) AS mn,
           SUM(total_amount) AS total_revenue
    FROM sales
    WHERE order_status NOT IN ('cancelled', 'returned')
      AND approval_status = 'approved'
    GROUP BY yr, mn
) rev
LEFT JOIN (
    SELECT YEAR(expense_date) AS yr, MONTH(expense_date) AS mn,
           SUM(amount) AS total_expenses
    FROM expenses
    GROUP BY yr, mn
) exp USING (yr, mn)
ORDER BY yr DESC, mn DESC;


-- Unread notifications
CREATE OR REPLACE VIEW vw_unread_notifications AS
SELECT
    n.recipient_id,
    u.username,
    u.role,
    COUNT(n.id)       AS unread_count,
    MIN(n.created_at) AS oldest_unread
FROM notifications n
JOIN users u ON u.id = n.recipient_id
WHERE n.is_read = FALSE
GROUP BY n.recipient_id, u.username, u.role;



-- TRIGGERS


DELIMITER $$

-- Auto-create inventory when product is added
CREATE TRIGGER trg_product_after_insert
AFTER INSERT ON products
FOR EACH ROW
BEGIN
    INSERT INTO inventory (product_id, quantity_in_stock)
    VALUES (NEW.id, 0);
END$$


-- Log user login
CREATE TRIGGER trg_user_login_audit
BEFORE UPDATE ON users
FOR EACH ROW
BEGIN
    IF NEW.last_login <> OLD.last_login OR
       (OLD.last_login IS NULL AND NEW.last_login IS NOT NULL) THEN
        INSERT INTO audit_logs (user_id, user_name, action, table_name, record_id, description)
        VALUES (NEW.id, NEW.username, 'LOGIN', 'users', NEW.id, 'User logged in');
    END IF;
END$$


-- Track inventory changes
CREATE TRIGGER trg_inventory_after_update
AFTER UPDATE ON inventory
FOR EACH ROW
BEGIN
    IF OLD.quantity_in_stock <> NEW.quantity_in_stock THEN
        INSERT INTO audit_logs (
            action, table_name, record_id,
            old_values, new_values, description
        ) VALUES (
            'UPDATE', 'inventory', NEW.id,
            JSON_OBJECT('quantity_in_stock', OLD.quantity_in_stock,
                         'quantity_reserved', OLD.quantity_reserved),
            JSON_OBJECT('quantity_in_stock', NEW.quantity_in_stock,
                         'quantity_reserved', NEW.quantity_reserved),
            CONCAT('Inventory changed for product_id=', NEW.product_id,
                   ' from ', OLD.quantity_in_stock, ' to ', NEW.quantity_in_stock)
        );
    END IF;
END$$


-- Notify accountants when rep order is created
CREATE TRIGGER trg_sale_after_insert
AFTER INSERT ON sales
FOR EACH ROW
BEGIN
    DECLARE done INT DEFAULT FALSE;
    DECLARE accountant_id INT;
    DECLARE rep_name VARCHAR(100);

    IF NEW.order_type = 'representative' THEN

        SELECT CONCAT(first_name, ' ', last_name)
        INTO rep_name
        FROM employees
        WHERE id = NEW.representative_id
        LIMIT 1;

        BEGIN
            DECLARE cur CURSOR FOR
                SELECT id FROM users
                WHERE role IN ('accountant', 'admin')
                  AND is_active = TRUE;
            DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = TRUE;

            OPEN cur;
            read_loop: LOOP
                FETCH cur INTO accountant_id;
                IF done THEN LEAVE read_loop; END IF;

                INSERT INTO notifications (
                    recipient_id, sender_id,
                    title, message, type,
                    reference_table, reference_id
                ) VALUES (
                    accountant_id, NEW.created_by,
                    CONCAT('New Order Awaiting Approval - ', NEW.sale_number),
                    CONCAT('Representative ', IFNULL(rep_name, 'Unknown'),
                           ' placed order ', NEW.sale_number,
                           ' totaling ', NEW.total_amount,
                           '. Please review and approve or reject.'),
                    'order_approval', 'sales', NEW.id
                );
            END LOOP;
            CLOSE cur;
        END;

        INSERT INTO audit_logs (
            user_id, action, table_name, record_id, description
        ) VALUES (
            NEW.created_by, 'CREATE', 'sales', NEW.id,
            CONCAT('Representative order ', NEW.sale_number, ' created - pending approval')
        );
    END IF;
END$$


-- Notify rep when order is approved/rejected
CREATE TRIGGER trg_sale_approval_update
AFTER UPDATE ON sales
FOR EACH ROW
BEGIN
    DECLARE rep_user_id INT;
    DECLARE notif_title VARCHAR(200);
    DECLARE notif_message TEXT;
    DECLARE notif_type VARCHAR(50);

    IF OLD.approval_status <> NEW.approval_status
       AND NEW.order_type = 'representative' THEN

        SELECT u.id INTO rep_user_id
        FROM users u
        JOIN employees e ON e.email = u.email
        WHERE e.id = NEW.representative_id
        LIMIT 1;

        IF NEW.approval_status = 'approved' THEN
            SET notif_title   = CONCAT('Order ', NEW.sale_number, ' APPROVED');
            SET notif_message = CONCAT('Your order ', NEW.sale_number,
                                       ' has been approved and will be processed.');
            SET notif_type    = 'order_approved';

            INSERT INTO audit_logs (
                user_id, action, table_name, record_id, description
            ) VALUES (
                NEW.approved_by, 'APPROVE', 'sales', NEW.id,
                CONCAT('Order ', NEW.sale_number, ' approved')
            );

        ELSEIF NEW.approval_status = 'rejected' THEN
            SET notif_title   = CONCAT('Order ', NEW.sale_number, ' REJECTED');
            SET notif_message = CONCAT('Your order ', NEW.sale_number,
                                       ' has been rejected. Reason: ',
                                       IFNULL(NEW.rejection_reason, 'No reason provided'));
            SET notif_type    = 'order_rejected';

            INSERT INTO audit_logs (
                user_id, action, table_name, record_id, description
            ) VALUES (
                NEW.approved_by, 'REJECT', 'sales', NEW.id,
                CONCAT('Order ', NEW.sale_number, ' rejected. Reason: ',
                       IFNULL(NEW.rejection_reason, 'N/A'))
            );
        END IF;

        IF rep_user_id IS NOT NULL AND notif_title IS NOT NULL THEN
            INSERT INTO notifications (
                recipient_id, sender_id,
                title, message, type,
                reference_table, reference_id
            ) VALUES (
                rep_user_id, NEW.approved_by,
                notif_title, notif_message, notif_type,
                'sales', NEW.id
            );
        END IF;
    END IF;
END$$

DELIMITER ;



