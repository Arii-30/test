DELIMITER $$

-- Approve order
CREATE PROCEDURE sp_approve_order (
    IN p_sale_id     INT,
    IN p_approved_by INT
)
BEGIN
    UPDATE sales
    SET approval_status = 'approved',
        approved_by     = p_approved_by,
        approved_at     = NOW(),
        order_status    = 'confirmed'
    WHERE id = p_sale_id
      AND approval_status = 'pending';
END$$


-- Reject order
CREATE PROCEDURE sp_reject_order (
    IN p_sale_id          INT,
    IN p_approved_by      INT,
    IN p_rejection_reason TEXT
)
BEGIN
    UPDATE sales
    SET approval_status  = 'rejected',
        approved_by      = p_approved_by,
        approved_at      = NOW(),
        rejection_reason = p_rejection_reason,
        order_status     = 'cancelled'
    WHERE id = p_sale_id
      AND approval_status = 'pending';
END$$


-- Record payment & update debt
CREATE PROCEDURE sp_record_payment (
    IN p_payment_number VARCHAR(30),
    IN p_debt_id        INT,
    IN p_amount         DECIMAL(14,2),
    IN p_date           DATE,
    IN p_notes          TEXT,
    IN p_created_by     INT
)
BEGIN
    START TRANSACTION;

    INSERT INTO payments (
        payment_number, debt_id, amount,
        payment_date, notes, created_by
    ) VALUES (
        p_payment_number, p_debt_id, p_amount,
        p_date, p_notes, p_created_by
    );

    IF p_debt_id IS NOT NULL THEN
        UPDATE debts
        SET paid_amount       = paid_amount + p_amount,
            last_payment_date = p_date,
            status = CASE
                WHEN (paid_amount + p_amount) >= original_amount THEN 'paid'
                ELSE 'partially_paid'
            END
        WHERE id = p_debt_id;
    END IF;

    COMMIT;
END$$


-- Daily sales report
CREATE PROCEDURE sp_daily_sales_report (IN p_date DATE)
BEGIN
    SELECT
        s.sale_number,
        CONCAT(c.first_name, ' ', IFNULL(c.last_name, '')) AS customer,
        CONCAT(e.first_name, ' ', e.last_name)             AS representative,
        s.order_type,
        s.approval_status,
        s.total_amount,
        s.paid_amount,
        s.due_amount,
        s.payment_status,
        s.order_status
    FROM sales s
    LEFT JOIN customers c ON c.id = s.customer_id
    LEFT JOIN employees e ON e.id = s.representative_id
    WHERE s.sale_date = p_date
    ORDER BY s.created_at;

    SELECT
        COUNT(*)             AS total_transactions,
        SUM(total_amount)    AS gross_sales,
        SUM(discount_amount) AS total_discounts,
        SUM(paid_amount)     AS total_collected,
        SUM(due_amount)      AS total_credit
    FROM sales
    WHERE sale_date = p_date
      AND order_status NOT IN ('cancelled', 'returned')
      AND approval_status = 'approved';
END$$


-- Mark single notification read
CREATE PROCEDURE sp_mark_notification_read (
    IN p_notification_id INT,
    IN p_user_id         INT
)
BEGIN
    UPDATE notifications
    SET is_read = TRUE, read_at = NOW()
    WHERE id = p_notification_id
      AND recipient_id = p_user_id;
END$$


-- Mark all notifications read
CREATE PROCEDURE sp_mark_all_notifications_read (
    IN p_user_id INT
)
BEGIN
    UPDATE notifications
    SET is_read = TRUE, read_at = NOW()
    WHERE recipient_id = p_user_id
      AND is_read = FALSE;
END$$

