DELIMITER $$

CREATE TRIGGER trg_purchase_item_after_insert
AFTER INSERT ON purchase_items
FOR EACH ROW
BEGIN
    UPDATE inventory
    SET quantity_in_stock = quantity_in_stock + NEW.quantity,
        last_restock_date = CURDATE()
    WHERE product_id = NEW.product_id;

    INSERT INTO inventory_transactions
        (product_id, transaction_type, quantity, notes, created_at)
    VALUES
        (NEW.product_id, 'purchase', NEW.quantity,
         CONCAT('Purchase ID: ', NEW.purchase_id), NOW());
END$$

CREATE TRIGGER trg_sale_item_after_insert
AFTER INSERT ON sale_items
FOR EACH ROW
BEGIN
    DECLARE the_sale_approved VARCHAR(20);
    
    SELECT approval_status INTO the_sale_approved
    FROM sales WHERE id = NEW.sale_id;
    
    -- Only deduct if sale is approved
    IF the_sale_approved = 'approved' THEN
        UPDATE inventory
        SET quantity_in_stock = quantity_in_stock - NEW.quantity,
            last_sold_date = CURDATE()
        WHERE product_id = NEW.product_id;

        INSERT INTO inventory_transactions
            (product_id, transaction_type, quantity, notes)
        VALUES
            (NEW.product_id, 'sale', -NEW.quantity,
             CONCAT('Sale ID: ', NEW.sale_id));
    END IF;
END$$

DELIMITER ;

DELIMITER $$

CREATE TRIGGER trg_low_stock_alert
AFTER UPDATE ON inventory
FOR EACH ROW
BEGIN
    DECLARE prod_name VARCHAR(200);
    DECLARE reorder   INT;

    IF NEW.quantity_in_stock < OLD.quantity_in_stock THEN
        SELECT p.name, p.reorder_level
        INTO prod_name, reorder
        FROM products p WHERE p.id = NEW.product_id;

        IF NEW.quantity_in_stock <= reorder THEN
            INSERT INTO notifications (
                recipient_id, title, message, type,
                reference_table, reference_id
            )
            SELECT
                u.id,
                CONCAT('⚠ Low Stock: ', prod_name),
                CONCAT(prod_name, ' has only ',
                       NEW.quantity_in_stock, ' units left.',
                       ' Reorder level: ', reorder),
                'low_stock', 'products', NEW.product_id
            FROM users u
            WHERE u.role IN ('admin', 'accountant')
              AND u.is_active = TRUE;
        END IF;
    END IF;
END$$

